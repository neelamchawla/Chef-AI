# Firebase (required for auth + saved plans)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API URL (optional — defaults to /api for same-origin proxy)
# Set this to your deployed Express/functions server in production.
VITE_API_URL=
