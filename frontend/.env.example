# Firebase (required for auth + saved plans)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API URL (optional — defaults to /api for same-origin proxy)
# Leave empty on Netlify; API is served via Netlify Functions at /api/*
# For local `npm run preview`, start the backend first: npm run dev:server
VITE_API_URL=
