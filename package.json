{
  "name": "cooking-ai-app",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered cooking to-do list micro-app",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:server": "npm run dev --prefix functions",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix functions",
    "install:all": "npm install && npm install --prefix frontend && npm install --prefix functions"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
